SOURCE 
module adder #(parameter N = 8)
(
    input  [N-1:0] A,
    input  [N-1:0] B,

    output [N-1:0] SUM,
    output CARRY
);

wire [N:0] temp;

assign temp = A + B;

assign SUM = temp[N-1:0];

assign CARRY = temp[N];

endmodule

SIMULATION ADDER_TB.V

`timescale 1ns / 1ps

module adder_tb;

parameter N = 8;

reg [N-1:0] A;
reg [N-1:0] B;

wire [N-1:0] SUM;
wire CARRY;

adder #(N) uut
(
    .A(A),
    .B(B),
    .SUM(SUM),
    .CARRY(CARRY)
);

initial
begin

    A = 8'd0;   B = 8'd0;
    #10;

    A = 8'd5;   B = 8'd3;
    #10;

    A = 8'd100; B = 8'd50;
    #10;

    A = 8'd255; B = 8'd1;
    #10;

    A = 8'd255; B = 8'd255;
    #10;

    $finish;

end

endmodule

